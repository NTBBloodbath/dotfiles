;------------------------------------------------;
;                                                ;
;                   MENU PARAMETERS              ;
;                                                ;
;------------------------------------------------;
[module/menu-apps]
type = custom/text

content = "ÔĒļ"
content-padding = 2
content-background = ${colors.red}
content-foreground = ${colors.black}
click-left = exec rofi -show combi

;------------------------------------------------;
;                                                ;
;                   BSPWM PARAMETERS             ;
;                                                ;
;------------------------------------------------;
[module/bspwm]
type = internal/bspwm
pin-workspaces = true
inline-mode = true
enable-click = true
enable-scroll = true
reverse-scroll = true
fuzzy-match = true

format = <label-state>
format-padding = 1

ws-icon-0 = I;ÓěĘ
ws-icon-1 = II;ÓĚÉ
ws-icon-2 = III;Óąó
ws-icon-3 = IV;ÔĘÖ
ws-icon-4 = V;Ôö¶

; NOTE: YOU CANNOT HAVE NAME AND ICON
; TOGETHER ONLY ONE OR THE OTHER!!

label-focused = %icon%
label-focused-foreground = ${colors.blue}
label-focused-padding = 1

label-occupied = %icon%
label-occupied-foreground = ${colors.foreground}
label-occupied-padding = 1

label-empty = %icon%
label-empty-foreground = ${colors.black-alt}
label-empty-padding = 1

;------------------------------------------------;
;                                                ;
;               XWORKSPACES PAMETERS             ;
;                                                ;
;------------------------------------------------;
[module/awesome]
type = internal/xworkspaces

pin-workspaces = false

enable-click = true
enable-scroll = true

icon-0 = 1;ÔėĮ
icon-1 = 2;ÔėĮ
icon-2 = 3;ÔėĮ
icon-3 = 4;ÔėĮ
icon-4 = 5;ÔėĮ
icon-default = ÔėĮ

format = <label-state>

label-monitor = %name%

label-active = Ôėģ
label-active-background = ${colors.background}
label-active-foreground = ${colors.blue}
label-active-padding = 1

label-occupied = ÔÜí
label-occupied-background = ${colors.background}
label-occupied-foreground = ${colors.foreground}
label-occupied-padding = 1

label-urgent = ÔĀ™
label-urgent-background = ${colors.background}
label-urgent-foreground = ${colors.red}
label-urgent-padding = 1

label-empty = ÔėĮ
label-empty-background = ${colors.background}
label-empty-foreground = ${colors.white}
label-empty-padding = 1

;------------------------------------------------;
;                                                ;
;               DATE PARAMETERS                  ;
;                                                ;
;------------------------------------------------;
[module/date]
type = internal/date
interval = 1.0
date =
time = %r

; if `date-alt` or `time-alt` is defined, clicking
; the module will toggle between formats
date-alt = %A, %d %B %Y
time-alt = %r

format = <label>
format-prefix = " Ôźļ "
format-background = ${colors.yellow}
format-foreground = ${colors.black}

label = %date% %time%
label-background = ${colors.yellow}
label-foreground = ${colors.black}

;------------------------------------------------;
;                                                ;
;       NOTIFICATIONS MENU PARAMETERS            ;
;                                                ;
;------------------------------------------------;
[module/dunst]
type = custom/ipc
initial = 1

format-background = ${colors.blue}
format-foreground = ${colors.black}

hook-0 = echo "%{A1:notify-send "Paused notifications" && dunstctl set-paused true && polybar-msg hook dunst 2:} ÔĖô %{A}" &
hook-1 = echo "%{A1:notify-send "Resumed notifications" && dunstctl set-paused false && polybar-msg hook dunst 1:} ÔĖö %{A}" &

;------------------------------------------------;
;                                                ;
;               POWER MENU PARAMETERS            ;
;                                                ;
;------------------------------------------------;
[module/powermenu]
type = custom/menu

expand-right = false

label-open = " Ô§§"
label-open-background = ${colors.background}
label-open-foreground = ${colors.red}
label-close = "Ôôē"
label-close-background = ${colors.background}
label-close-foreground = ${colors.red}
label-separator = "   "
label-separator-background = ${colors.background}
label-separator-foreground = ${colors.white}

menu-0-0-background = ${colors.background}
menu-0-0-foreground = ${colors.white}
menu-0-1-background = ${colors.background}
menu-0-1-foreground = ${colors.white}
menu-0-2-background = ${colors.background}
menu-0-2-foreground = ${colors.white}

menu-0-0 = "Reboot"
menu-0-0-exec = reboot
menu-0-1 = "Shutdown"
menu-0-1-exec = poweroff
menu-0-2 = "Log out"
menu-0-2-exec = awesome quit

;------------------------------------------------;
;                                                ;
;               RAM MODULE PARAMETERS            ;
;                                                ;
;------------------------------------------------;
[module/memory]
type = internal/memory
interval = 2

format = <label>
format-prefix = "  Ôčõ "
format-background = ${colors.green}
format-foreground = ${colors.black}

label = RAM: %percentage_used%%
label-background = ${colors.green}
label-foreground = ${colors.black}

;------------------------------------------------;
;                                                ;
;               CPU MODULE PARAMETERS            ;
;                                                ;
;------------------------------------------------;
[module/cpu]
type = internal/cpu
interval = 2

format = <label>
format-prefix = " Ô°ö "
format-background = ${colors.magenta}
format-foreground = ${colors.black}

label = CPU: %percentage%%
label-padding = 1
label-background = ${colors.magenta}
label-foreground = ${colors.black}

;------------------------------------------------;
;                                                ;
;            GITHUB MODULE PARAMETERS            ;
;                                                ;
;------------------------------------------------;
[module/github]
type = internal/github

interval = 30

token = ${env:GITHUB_TOKEN}
user = NTBBloodbath

empty-notifications = true
api-url = https://api.github.com/

label = Ôāõ  Notifications: %notifications%
label-offline = Ôāõ  Offline

;------------- USER DEFINED MODULES --------------
; These modules require scripts to run, you can find
; the scripts and how to run them here:
; https://github.com/jaagr/polybar/wiki/User-contributed-modules

;------------------------------------------------;
;                                                ;
;               VOLUME PARAMETERS                ;
;                                                ;
;------------------------------------------------;
[module/pavolume]
type = custom/script
interval = 1
label=%output%%
label-padding = 2
label-background = ${colors.green}
label-foreground = ${colors.black}
exec = ~/.config/polybar/scripts/pavolume.sh
click-right = exec pavucontrol
click-left = ~/.config/polybar/scripts/pavolume.sh --togmute
scroll-up = ~/.config/polybar/scripts/pavolume.sh --up
scroll-down = ~/.config/polybar/scripts/pavolume.sh --down

;-----------------------------------------------;
;                                               ;
;               Browser media control           ;
;                                               ;
;-----------------------------------------------;
[module/cmus]
type = custom/script

exec = ~/.config/polybar/scripts/cmus.sh
interval = 1

click-left = cmus-remote --pause
scroll-down = cmus-remote --next
scroll-up = cmus-remote --prev

label-maxlen = 150

