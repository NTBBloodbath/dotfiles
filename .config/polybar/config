[colors]
##### doom-one colorscheme #####
background = #21242a
foreground = #bbc2cf

black   = #1c1d27
red     = #ff6c6b
green   = #98be65
yellow  = #ECBE7B
blue    = #51afef
magenta = #c768dd
cyan    = #46D9FF
white   = #efefef

##### OneDark colorscheme #####
black-alt   = #1c1d27
red-alt     = #e06c75
green-alt   = #98c379
yellow-alt  = #e5c07b
